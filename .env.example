# Base URL of the tracking backend's admin API.
# In dev the Vite proxy rewrites /api → http://localhost:3000 by default,
# so you can leave this empty locally.
VITE_API_BASE_URL=

# When mounted under a sub-path of the admin dashboard (e.g. /tracking),
# set this so React Router and asset URLs resolve correctly.
# VITE_APP_BASE=/tracking

# Optional: override the dev proxy target (defaults to http://localhost:3000)
# VITE_API_PROXY=http://localhost:3000
